ISO-10303-21;
HEADER;
FILE_DESCRIPTION(('Sample STEP file - cube with 6 planar faces'),'2;1');
FILE_NAME('SampleCube.step','2024-01-01T00:00:00',('Author'),(''),
  'STEP Viewer Delphi','','');
FILE_SCHEMA(('AUTOMOTIVE_DESIGN { 1 0 10303 214 1 1 1 1 }'));
ENDSEC;

DATA;

/* ---- Cartesian points (cube corners, size 20x20x20 mm) ---- */
#1 = CARTESIAN_POINT('',( 0.0, 0.0, 0.0));
#2 = CARTESIAN_POINT('',( 20.0, 0.0, 0.0));
#3 = CARTESIAN_POINT('',( 20.0, 20.0, 0.0));
#4 = CARTESIAN_POINT('',( 0.0, 20.0, 0.0));
#5 = CARTESIAN_POINT('',( 0.0, 0.0, 20.0));
#6 = CARTESIAN_POINT('',( 20.0, 0.0, 20.0));
#7 = CARTESIAN_POINT('',( 20.0, 20.0, 20.0));
#8 = CARTESIAN_POINT('',( 0.0, 20.0, 20.0));

/* ---- Directions ---- */
#10 = DIRECTION('',(1.0,0.0,0.0));
#11 = DIRECTION('',(0.0,1.0,0.0));
#12 = DIRECTION('',(0.0,0.0,1.0));
#13 = DIRECTION('',(-1.0,0.0,0.0));
#14 = DIRECTION('',(0.0,-1.0,0.0));
#15 = DIRECTION('',(0.0,0.0,-1.0));

/* ---- Axis placements for 6 faces ---- */
/* Bottom face Z- */
#20 = AXIS2_PLACEMENT_3D('', #1, #15, #10);
/* Top face Z+ */
#21 = AXIS2_PLACEMENT_3D('', #5, #12, #10);
/* Front face Y- */
#22 = AXIS2_PLACEMENT_3D('', #1, #14, #10);
/* Back face Y+ */
#23 = AXIS2_PLACEMENT_3D('', #4, #11, #10);
/* Left face X- */
#24 = AXIS2_PLACEMENT_3D('', #1, #13, #12);
/* Right face X+ */
#25 = AXIS2_PLACEMENT_3D('', #2, #10, #12);

/* ---- Planes ---- */
#30 = PLANE('bottom', #20);
#31 = PLANE('top',    #21);
#32 = PLANE('front',  #22);
#33 = PLANE('back',   #23);
#34 = PLANE('left',   #24);
#35 = PLANE('right',  #25);

/* ---- Vertex points ---- */
#40 = VERTEX_POINT('', #1);
#41 = VERTEX_POINT('', #2);
#42 = VERTEX_POINT('', #3);
#43 = VERTEX_POINT('', #4);
#44 = VERTEX_POINT('', #5);
#45 = VERTEX_POINT('', #6);
#46 = VERTEX_POINT('', #7);
#47 = VERTEX_POINT('', #8);

/* ---- Lines for the 12 cube edges ---- */
#50 = VECTOR('', #10, 20.0);   /* +X direction, len 20 */
#51 = VECTOR('', #11, 20.0);   /* +Y direction, len 20 */
#52 = VECTOR('', #12, 20.0);   /* +Z direction, len 20 */

#53 = LINE('e01', #1, #50);   /* P0->P1 bottom front  */
#54 = LINE('e12', #2, #51);   /* P1->P2 bottom right  */
#55 = LINE('e23', #3, #13, 20.0);
#56 = LINE('e30', #4, #14, 20.0);

/* Simplified: use POLY_LOOP for face bounds (easier to parse) */

/* ---- Bottom face (Z=0): vertices 0,3,2,1 (clockwise from below = CW = outward -Z) ---- */
#100 = POLY_LOOP('', (#1, #4, #3, #2));
#101 = FACE_OUTER_BOUND('', #100, .T.);
#102 = ADVANCED_FACE('bottom', (#101), #30, .F.);

/* ---- Top face (Z=20): vertices 4,5,6,7 ---- */
#110 = POLY_LOOP('', (#5, #6, #7, #8));
#111 = FACE_OUTER_BOUND('', #110, .T.);
#112 = ADVANCED_FACE('top', (#111), #31, .T.);

/* ---- Front face (Y=0): vertices 0,1,5,4 ---- */
#120 = POLY_LOOP('', (#1, #2, #6, #5));
#121 = FACE_OUTER_BOUND('', #120, .T.);
#122 = ADVANCED_FACE('front', (#121), #32, .F.);

/* ---- Back face (Y=20): vertices 3,4(=8 in 1-based),7,6 ---- */
#130 = POLY_LOOP('', (#4, #3, #7, #8));
#131 = FACE_OUTER_BOUND('', #130, .T.);
#132 = ADVANCED_FACE('back', (#131), #33, .T.);

/* ---- Left face (X=0): vertices 0,4(=8),7(=8),3 ---- */
#140 = POLY_LOOP('', (#1, #5, #8, #4));
#141 = FACE_OUTER_BOUND('', #140, .T.);
#142 = ADVANCED_FACE('left', (#141), #34, .F.);

/* ---- Right face (X=20): vertices 1,2,6,5 ---- */
#150 = POLY_LOOP('', (#2, #3, #7, #6));
#151 = FACE_OUTER_BOUND('', #150, .T.);
#152 = ADVANCED_FACE('right', (#151), #35, .T.);

/* ---- Shell and BREP ---- */
#200 = CLOSED_SHELL('cube_shell', (#102, #112, #122, #132, #142, #152));
#201 = MANIFOLD_SOLID_BREP('cube', #200);

/* ---- Shape representation ---- */
#300 = ( GEOMETRIC_REPRESENTATION_CONTEXT(3)
         GLOBAL_UNCERTAINTY_ASSIGNED_CONTEXT((#301))
         GLOBAL_UNIT_ASSIGNED_CONTEXT((#302,#303,#304))
         REPRESENTATION_CONTEXT('model','3D') );
#301 = UNCERTAINTY_MEASURE_WITH_UNIT(LENGTH_MEASURE(1.0E-06),#302,'','');
#302 = ( LENGTH_UNIT() NAMED_UNIT(*) SI_UNIT(.MILLI.,.METRE.) );
#303 = ( NAMED_UNIT(*) PLANE_ANGLE_UNIT() SI_UNIT($,.RADIAN.) );
#304 = ( NAMED_UNIT(*) SI_UNIT($,.STERADIAN.) SOLID_ANGLE_UNIT() );
#400 = SHAPE_DEFINITION_REPRESENTATION(#401,#402);
#401 = PRODUCT_DEFINITION_SHAPE('','',#403);
#402 = ADVANCED_BREP_SHAPE_REPRESENTATION('',(#201),#300);
#403 = PRODUCT_DEFINITION('','',#404,#405);
#404 = PRODUCT_DEFINITION_FORMATION('','',#406);
#405 = PRODUCT_DEFINITION_CONTEXT('part definition',#407,'design');
#406 = PRODUCT('Cube','Cube','Sample cube',(#408));
#407 = APPLICATION_CONTEXT('automotive_design');
#408 = PRODUCT_CONTEXT('',#407,'mechanical');

ENDSEC;
END-ISO-10303-21;
