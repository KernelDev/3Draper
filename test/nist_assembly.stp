FILE_SCHEMA(('AUTOMOTIVE_DESIGN { 1 0 10303 214 1 1 1 1 }'));
ENDSEC;
DATA;

/* Assembly: two cubes at different positions */
/* Part 1: small cube at origin (0,0,0) size 5 */
/* Part 2: small cube at (8,0,0) size 5 */

/* ============================================================ */
