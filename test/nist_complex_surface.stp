ISO-10303-21;
HEADER;
FILE_DESCRIPTION(('NIST STEP Test Suite - Model with NURBS Surface'),'2;1');
FILE_NAME('nist_complex_surface.stp','2024-01-01T00:00:00',('NIST'),(''),
  '3Draper NIST Test Suite','','');
FILE_SCHEMA(('AUTOMOTIVE_DESIGN { 1 0 10303 214 1 1 1 1 }'));
ENDSEC;
DATA;

/* A simple model with a B-spline surface (gentle hill shape) */
/* 6 faces: bottom plane, 4 side planes, top B-spline surface */

/* ---- Cartesian points ---- */
#1 = CARTESIAN_POINT('',(0.0,0.0,0.0));
#2 = CARTESIAN_POINT('',(10.0,0.0,0.0));
#3 = CARTESIAN_POINT('',(10.0,10.0,0.0));
#4 = CARTESIAN_POINT('',(0.0,10.0,0.0));
#5 = CARTESIAN_POINT('',(0.0,0.0,1.0));
#6 = CARTESIAN_POINT('',(10.0,0.0,1.0));
#7 = CARTESIAN_POINT('',(10.0,10.0,1.0));
#8 = CARTESIAN_POINT('',(0.0,10.0,1.0));
#9 = CARTESIAN_POINT('',(5.0,5.0,3.0));

/* ---- Directions ---- */
#10 = DIRECTION('',(1.0,0.0,0.0));
#11 = DIRECTION('',(0.0,1.0,0.0));
#12 = DIRECTION('',(0.0,0.0,1.0));
#13 = DIRECTION('',(-1.0,0.0,0.0));
#14 = DIRECTION('',(0.0,-1.0,0.0));
#15 = DIRECTION('',(0.0,0.0,-1.0));

/* ---- Vectors ---- */
#20 = VECTOR('',#10,10.0);
#21 = VECTOR('',#11,10.0);
#22 = VECTOR('',#12,1.0);
#23 = VECTOR('',#13,10.0);
#24 = VECTOR('',#14,10.0);
#25 = VECTOR('',#15,1.0);

/* ---- Axis placements ---- */
#30 = AXIS2_PLACEMENT_3D('',#1,#15,#10);
#31 = AXIS2_PLACEMENT_3D('',#1,#14,#10);
#32 = AXIS2_PLACEMENT_3D('',#4,#11,#10);
#33 = AXIS2_PLACEMENT_3D('',#1,#13,#12);
#34 = AXIS2_PLACEMENT_3D('',#2,#10,#12);

/* ---- Planes ---- */
#40 = PLANE('',#30);
#41 = PLANE('',#31);
#42 = PLANE('',#32);
#43 = PLANE('',#33);
#44 = PLANE('',#34);

/* ---- B-spline surface ---- */
/* A 2x2 degree B-spline surface with 3x3 control points forming a gentle hill */
/* Control points:
   (0,0,1)  (5,0,1)   (10,0,1)
   (0,5,1)  (5,5,3)   (10,5,1)
   (0,10,1) (5,10,1)  (10,10,1)
*/
#45 = B_SPLINE_SURFACE_WITH_KNOTS('',2,2,
  ((#100,#101,#102),(#103,#104,#105),(#106,#107,#108)),
  .UNSPECIFIED.,.F.,.F.,.F.,
  (3,3),(3,3),
  (0.0,1.0),(0.0,1.0),
  .UNSPECIFIED.);

/* Control point lists for B-spline surface */
#100 = CARTESIAN_POINT('',(0.0,0.0,1.0));
#101 = CARTESIAN_POINT('',(5.0,0.0,1.0));
#102 = CARTESIAN_POINT('',(10.0,0.0,1.0));
#103 = CARTESIAN_POINT('',(0.0,5.0,1.0));
#104 = CARTESIAN_POINT('',(5.0,5.0,3.0));
#105 = CARTESIAN_POINT('',(10.0,5.0,1.0));
#106 = CARTESIAN_POINT('',(0.0,10.0,1.0));
#107 = CARTESIAN_POINT('',(5.0,10.0,1.0));
#108 = CARTESIAN_POINT('',(10.0,10.0,1.0));

/* ---- Vertex points ---- */
#50 = VERTEX_POINT('',#1);
#51 = VERTEX_POINT('',#2);
#52 = VERTEX_POINT('',#3);
#53 = VERTEX_POINT('',#4);
#54 = VERTEX_POINT('',#5);
#55 = VERTEX_POINT('',#6);
#56 = VERTEX_POINT('',#7);
#57 = VERTEX_POINT('',#8);

/* ---- Edge curves ---- */
/* Bottom edges */
#60 = LINE('',#1,#20);
#61 = LINE('',#2,#21);
#62 = LINE('',#3,#23);
#63 = LINE('',#4,#24);
/* Vertical edges */
#64 = LINE('',#1,#22);
#65 = LINE('',#2,#22);
#66 = LINE('',#3,#22);
#67 = LINE('',#4,#22);
/* Top edges (straight lines between corner vertices) */
#68 = LINE('',#5,#20);
#69 = LINE('',#6,#21);
#70 = LINE('',#7,#23);
#71 = LINE('',#8,#24);

#80 = EDGE_CURVE('',#50,#51,#60,.T.);
#81 = EDGE_CURVE('',#51,#52,#61,.T.);
#82 = EDGE_CURVE('',#52,#53,#62,.T.);
#83 = EDGE_CURVE('',#53,#50,#63,.T.);
#84 = EDGE_CURVE('',#50,#54,#64,.T.);
#85 = EDGE_CURVE('',#51,#55,#65,.T.);
#86 = EDGE_CURVE('',#52,#56,#66,.T.);
#87 = EDGE_CURVE('',#53,#57,#67,.T.);
#88 = EDGE_CURVE('',#54,#55,#68,.T.);
#89 = EDGE_CURVE('',#55,#56,#69,.T.);
#90 = EDGE_CURVE('',#56,#57,#70,.T.);
#91 = EDGE_CURVE('',#57,#54,#71,.T.);

/* ---- Oriented edges ---- */
/* Bottom face */
#110 = ORIENTED_EDGE('',*,*,#80,.F.);
#111 = ORIENTED_EDGE('',*,*,#81,.F.);
#112 = ORIENTED_EDGE('',*,*,#82,.F.);
#113 = ORIENTED_EDGE('',*,*,#83,.F.);

/* Top face (B-spline surface) */
#114 = ORIENTED_EDGE('',*,*,#88,.T.);
#115 = ORIENTED_EDGE('',*,*,#89,.T.);
#116 = ORIENTED_EDGE('',*,*,#90,.T.);
#117 = ORIENTED_EDGE('',*,*,#91,.T.);

/* Front face (y=0) */
#118 = ORIENTED_EDGE('',*,*,#80,.T.);
#119 = ORIENTED_EDGE('',*,*,#85,.T.);
#120 = ORIENTED_EDGE('',*,*,#88,.F.);
#121 = ORIENTED_EDGE('',*,*,#84,.F.);

/* Back face (y=10) */
#122 = ORIENTED_EDGE('',*,*,#82,.F.);
#123 = ORIENTED_EDGE('',*,*,#86,.T.);
#124 = ORIENTED_EDGE('',*,*,#90,.F.);
#125 = ORIENTED_EDGE('',*,*,#87,.F.);

/* Left face (x=0) */
#126 = ORIENTED_EDGE('',*,*,#83,.T.);
#127 = ORIENTED_EDGE('',*,*,#87,.T.);
#128 = ORIENTED_EDGE('',*,*,#91,.F.);
#129 = ORIENTED_EDGE('',*,*,#84,.T.);

/* Right face (x=10) */
#130 = ORIENTED_EDGE('',*,*,#81,.F.);
#131 = ORIENTED_EDGE('',*,*,#86,.F.);
#132 = ORIENTED_EDGE('',*,*,#89,.F.);
#133 = ORIENTED_EDGE('',*,*,#85,.F.);

/* ---- Edge loops ---- */
#140 = EDGE_LOOP('',(#110,#111,#112,#113));
#141 = EDGE_LOOP('',(#114,#115,#116,#117));
#142 = EDGE_LOOP('',(#118,#119,#120,#121));
#143 = EDGE_LOOP('',(#122,#123,#124,#125));
#144 = EDGE_LOOP('',(#126,#127,#128,#129));
#145 = EDGE_LOOP('',(#130,#131,#132,#133));

/* ---- Face bounds ---- */
#150 = FACE_OUTER_BOUND('',#140,.T.);
#151 = FACE_OUTER_BOUND('',#141,.T.);
#152 = FACE_OUTER_BOUND('',#142,.T.);
#153 = FACE_OUTER_BOUND('',#143,.T.);
#154 = FACE_OUTER_BOUND('',#144,.T.);
#155 = FACE_OUTER_BOUND('',#145,.T.);

/* ---- Advanced faces ---- */
#160 = ADVANCED_FACE('',(#150),#40,.F.);
#161 = ADVANCED_FACE('',(#151),#45,.T.);
#162 = ADVANCED_FACE('',(#152),#41,.F.);
#163 = ADVANCED_FACE('',(#153),#42,.T.);
#164 = ADVANCED_FACE('',(#154),#43,.F.);
#165 = ADVANCED_FACE('',(#155),#44,.T.);

/* ---- Shell and BREP ---- */
#170 = CLOSED_SHELL('',(#160,#161,#162,#163,#164,#165));
#171 = MANIFOLD_SOLID_BREP('nist_complex_surface',#170);

/* ---- Shape representation ---- */
#300 = ( GEOMETRIC_REPRESENTATION_CONTEXT(3)
         GLOBAL_UNCERTAINTY_ASSIGNED_CONTEXT((#301))
         GLOBAL_UNIT_ASSIGNED_CONTEXT((#302,#303,#304))
         REPRESENTATION_CONTEXT('model','3D') );
#301 = UNCERTAINTY_MEASURE_WITH_UNIT(LENGTH_MEASURE(1.0E-06),#302,'','');
#302 = ( LENGTH_UNIT() NAMED_UNIT(*) SI_UNIT(.MILLI.,.METRE.) );
#303 = ( NAMED_UNIT(*) PLANE_ANGLE_UNIT() SI_UNIT($,.RADIAN.) );
#304 = ( NAMED_UNIT(*) SI_UNIT($,.STERADIAN.) SOLID_ANGLE_UNIT() );
#400 = SHAPE_DEFINITION_REPRESENTATION(#401,#402);
#401 = PRODUCT_DEFINITION_SHAPE('','',#403);
#402 = ADVANCED_BREP_SHAPE_REPRESENTATION('',(#171),#300);
#403 = PRODUCT_DEFINITION('','',#404,#405);
#404 = PRODUCT_DEFINITION_FORMATION('','',#406);
#405 = PRODUCT_DEFINITION_CONTEXT('part definition',#407,'design');
#406 = PRODUCT('NIST_NURBS','NIST_NURBS','NURBS surface model',(#408));
#407 = APPLICATION_CONTEXT('automotive_design');
#408 = PRODUCT_CONTEXT('',#407,'mechanical');

ENDSEC;
END-ISO-10303-21;
