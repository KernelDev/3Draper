ISO-10303-21;
HEADER;
FILE_DESCRIPTION(('NIST STEP Test Suite - Simple Unit Cube'),'2;1');
FILE_NAME('nist_cube.stp','2024-01-01T00:00:00',('NIST'),(''),
  '3Draper NIST Test Suite','','');
FILE_SCHEMA(('AUTOMOTIVE_DESIGN { 1 0 10303 214 1 1 1 1 }'));
ENDSEC;
DATA;

/* ---- Cartesian points (unit cube corners) ---- */
#1 = CARTESIAN_POINT('',(0.0,0.0,0.0));
#2 = CARTESIAN_POINT('',(1.0,0.0,0.0));
#3 = CARTESIAN_POINT('',(1.0,1.0,0.0));
#4 = CARTESIAN_POINT('',(0.0,1.0,0.0));
#5 = CARTESIAN_POINT('',(0.0,0.0,1.0));
#6 = CARTESIAN_POINT('',(1.0,0.0,1.0));
#7 = CARTESIAN_POINT('',(1.0,1.0,1.0));
#8 = CARTESIAN_POINT('',(0.0,1.0,1.0));

/* ---- Directions ---- */
#10 = DIRECTION('',(1.0,0.0,0.0));
#11 = DIRECTION('',(0.0,1.0,0.0));
#12 = DIRECTION('',(0.0,0.0,1.0));
#13 = DIRECTION('',(-1.0,0.0,0.0));
#14 = DIRECTION('',(0.0,-1.0,0.0));
#15 = DIRECTION('',(0.0,0.0,-1.0));

/* ---- Vectors ---- */
#50 = VECTOR('',#10,1.0);
#51 = VECTOR('',#11,1.0);
#52 = VECTOR('',#12,1.0);
#53 = VECTOR('',#13,1.0);
#54 = VECTOR('',#14,1.0);
#55 = VECTOR('',#15,1.0);

/* ---- Axis placements for 6 faces ---- */
#20 = AXIS2_PLACEMENT_3D('',#1,#15,#10);
#21 = AXIS2_PLACEMENT_3D('',#5,#12,#10);
#22 = AXIS2_PLACEMENT_3D('',#1,#14,#10);
#23 = AXIS2_PLACEMENT_3D('',#4,#11,#10);
#24 = AXIS2_PLACEMENT_3D('',#1,#13,#12);
#25 = AXIS2_PLACEMENT_3D('',#2,#10,#12);

/* ---- Planes ---- */
#30 = PLANE('',#20);
#31 = PLANE('',#21);
#32 = PLANE('',#22);
#33 = PLANE('',#23);
#34 = PLANE('',#24);
#35 = PLANE('',#25);

/* ---- Vertex points ---- */
#40 = VERTEX_POINT('',#1);
#41 = VERTEX_POINT('',#2);
#42 = VERTEX_POINT('',#3);
#43 = VERTEX_POINT('',#4);
#44 = VERTEX_POINT('',#5);
#45 = VERTEX_POINT('',#6);
#46 = VERTEX_POINT('',#7);
#47 = VERTEX_POINT('',#8);

/* ---- Edge curves (12 edges of the cube) ---- */
#60 = LINE('',#1,#50);
#61 = LINE('',#2,#51);
#62 = LINE('',#3,#53);
#63 = LINE('',#4,#54);
#64 = LINE('',#5,#50);
#65 = LINE('',#6,#51);
#66 = LINE('',#7,#53);
#67 = LINE('',#8,#54);
#68 = LINE('',#1,#52);
#69 = LINE('',#2,#52);
#70 = LINE('',#3,#52);
#71 = LINE('',#4,#52);

#80 = EDGE_CURVE('',#40,#41,#60,.T.);
#81 = EDGE_CURVE('',#41,#42,#61,.T.);
#82 = EDGE_CURVE('',#42,#43,#62,.T.);
#83 = EDGE_CURVE('',#43,#40,#63,.T.);
#84 = EDGE_CURVE('',#44,#45,#64,.T.);
#85 = EDGE_CURVE('',#45,#46,#65,.T.);
#86 = EDGE_CURVE('',#46,#47,#66,.T.);
#87 = EDGE_CURVE('',#47,#44,#67,.T.);
#88 = EDGE_CURVE('',#40,#44,#68,.T.);
#89 = EDGE_CURVE('',#41,#45,#69,.T.);
#90 = EDGE_CURVE('',#42,#46,#70,.T.);
#91 = EDGE_CURVE('',#43,#47,#71,.T.);

/* ---- Oriented edges ---- */
#100 = ORIENTED_EDGE('',*,*,#80,.F.);
#101 = ORIENTED_EDGE('',*,*,#81,.F.);
#102 = ORIENTED_EDGE('',*,*,#82,.F.);
#103 = ORIENTED_EDGE('',*,*,#83,.F.);

#110 = ORIENTED_EDGE('',*,*,#84,.T.);
#111 = ORIENTED_EDGE('',*,*,#85,.T.);
#112 = ORIENTED_EDGE('',*,*,#86,.T.);
#113 = ORIENTED_EDGE('',*,*,#87,.T.);

#120 = ORIENTED_EDGE('',*,*,#80,.T.);
#121 = ORIENTED_EDGE('',*,*,#89,.T.);
#122 = ORIENTED_EDGE('',*,*,#84,.F.);
#123 = ORIENTED_EDGE('',*,*,#88,.F.);

#130 = ORIENTED_EDGE('',*,*,#82,.F.);
#131 = ORIENTED_EDGE('',*,*,#90,.T.);
#132 = ORIENTED_EDGE('',*,*,#86,.F.);
#133 = ORIENTED_EDGE('',*,*,#91,.F.);

#140 = ORIENTED_EDGE('',*,*,#83,.T.);
#141 = ORIENTED_EDGE('',*,*,#91,.T.);
#142 = ORIENTED_EDGE('',*,*,#87,.F.);
#143 = ORIENTED_EDGE('',*,*,#88,.T.);

#150 = ORIENTED_EDGE('',*,*,#81,.F.);
#151 = ORIENTED_EDGE('',*,*,#90,.F.);
#152 = ORIENTED_EDGE('',*,*,#85,.F.);
#153 = ORIENTED_EDGE('',*,*,#89,.F.);

/* ---- Edge loops ---- */
#160 = EDGE_LOOP('',(#100,#101,#102,#103));
#161 = EDGE_LOOP('',(#110,#111,#112,#113));
#162 = EDGE_LOOP('',(#120,#121,#122,#123));
#163 = EDGE_LOOP('',(#130,#131,#132,#133));
#164 = EDGE_LOOP('',(#140,#141,#142,#143));
#165 = EDGE_LOOP('',(#150,#151,#152,#153));

/* ---- Face bounds ---- */
#170 = FACE_OUTER_BOUND('',#160,.T.);
#171 = FACE_OUTER_BOUND('',#161,.T.);
#172 = FACE_OUTER_BOUND('',#162,.T.);
#173 = FACE_OUTER_BOUND('',#163,.T.);
#174 = FACE_OUTER_BOUND('',#164,.T.);
#175 = FACE_OUTER_BOUND('',#165,.T.);

/* ---- Advanced faces ---- */
#180 = ADVANCED_FACE('',(#170),#30,.F.);
#181 = ADVANCED_FACE('',(#171),#31,.T.);
#182 = ADVANCED_FACE('',(#172),#32,.F.);
#183 = ADVANCED_FACE('',(#173),#33,.T.);
#184 = ADVANCED_FACE('',(#174),#34,.F.);
#185 = ADVANCED_FACE('',(#175),#35,.T.);

/* ---- Shell and BREP ---- */
#200 = CLOSED_SHELL('',(#180,#181,#182,#183,#184,#185));
#201 = MANIFOLD_SOLID_BREP('nist_cube',#200);

/* ---- Shape representation ---- */
#300 = ( GEOMETRIC_REPRESENTATION_CONTEXT(3)
         GLOBAL_UNCERTAINTY_ASSIGNED_CONTEXT((#301))
         GLOBAL_UNIT_ASSIGNED_CONTEXT((#302,#303,#304))
         REPRESENTATION_CONTEXT('model','3D') );
#301 = UNCERTAINTY_MEASURE_WITH_UNIT(LENGTH_MEASURE(1.0E-06),#302,'','');
#302 = ( LENGTH_UNIT() NAMED_UNIT(*) SI_UNIT(.MILLI.,.METRE.) );
#303 = ( NAMED_UNIT(*) PLANE_ANGLE_UNIT() SI_UNIT($,.RADIAN.) );
#304 = ( NAMED_UNIT(*) SI_UNIT($,.STERADIAN.) SOLID_ANGLE_UNIT() );
#400 = SHAPE_DEFINITION_REPRESENTATION(#401,#402);
#401 = PRODUCT_DEFINITION_SHAPE('','',#403);
#402 = ADVANCED_BREP_SHAPE_REPRESENTATION('',(#201),#300);
#403 = PRODUCT_DEFINITION('','',#404,#405);
#404 = PRODUCT_DEFINITION_FORMATION('','',#406);
#405 = PRODUCT_DEFINITION_CONTEXT('part definition',#407,'design');
#406 = PRODUCT('NIST_Cube','NIST_Cube','Simple unit cube',(#408));
#407 = APPLICATION_CONTEXT('automotive_design');
#408 = PRODUCT_CONTEXT('',#407,'mechanical');

ENDSEC;
END-ISO-10303-21;
